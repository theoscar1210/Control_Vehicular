#------------------------------------------------------------------------------
# CONFIGURACIÓN DE APLICACIÓN - Control Vehicular
#------------------------------------------------------------------------------
APP_NAME="Control Vehicular"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Bogota
APP_URL=http://localhost

# Configuración de idioma (Colombia)
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

# Modo mantenimiento
APP_MAINTENANCE_DRIVER=file

#------------------------------------------------------------------------------
# SERVIDOR PHP
#------------------------------------------------------------------------------
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

#------------------------------------------------------------------------------
# LOGS
#------------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

#------------------------------------------------------------------------------
# BASE DE DATOS - MySQL
#------------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=control_vehicular
DB_USERNAME=root
DB_PASSWORD=

#------------------------------------------------------------------------------
# SESIONES Y CACHE
#------------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict

CACHE_STORE=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

#------------------------------------------------------------------------------
# REDIS (Opcional - para cache/colas en producción)
#------------------------------------------------------------------------------
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

#------------------------------------------------------------------------------
# CORREO ELECTRÓNICO - Alertas Semanales
#------------------------------------------------------------------------------
# Para desarrollo (log)
MAIL_MAILER=log

# Para producción (SMTP) - Descomentar y configurar:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=tu-correo@gmail.com
# MAIL_PASSWORD=tu-app-password
# MAIL_ENCRYPTION=tls

MAIL_FROM_ADDRESS="alertas@control-vehicular.com"
MAIL_FROM_NAME="${APP_NAME}"

#------------------------------------------------------------------------------
# SANCTUM - Autenticación API
#------------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000
SANCTUM_TOKEN_EXPIRATION=1440

#------------------------------------------------------------------------------
# GOOGLE DRIVE - Almacenamiento de documentos
#------------------------------------------------------------------------------
# ID de la carpeta raíz en Google Drive donde se almacenarán los documentos
GOOGLE_DRIVE_FOLDER_ID=
# Credenciales OAuth 2.0
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=

#------------------------------------------------------------------------------
# VITE
#------------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

#------------------------------------------------------------------------------
# PRODUCCIÓN - Checklist obligatorio antes de desplegar
#------------------------------------------------------------------------------
# APP_ENV=production
# APP_DEBUG=false                   ← CRÍTICO: nunca true en producción
# APP_URL=https://tu-dominio.com
# LOG_LEVEL=warning                 ← nunca 'debug' en producción
# SESSION_ENCRYPT=true
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=strict
# BCRYPT_ROUNDS=12
